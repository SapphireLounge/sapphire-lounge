# Payment Configuration
REACT_APP_PAYMENT_PROVIDER=mock # Options: mock, stripe, paypal
REACT_APP_PAYMENT_PUBLIC_KEY=your_public_key_here

# Stripe Configuration (when using Stripe)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# PayPal Configuration (when using PayPal)
REACT_APP_PAYPAL_CLIENT_ID=your_client_id_here
